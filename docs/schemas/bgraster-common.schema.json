    "networkTable": {
      "type": "object",
      "description": "See the sections below for a full explanation of filtering, formatting, substitution tokens, and address origins.",
      "x-bgraster-doc": {
        "order": 11,
        "heading": "[network]",
        "showDefaults": true
      },
      "additionalProperties": false,
      "properties": {
        "render": {
          "type": "boolean",
          "default": false,
          "description": "Set to true to enable the dedicated network block. The ${Network} token in text blocks always works regardless."
        },
        "x": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "10vw"
          ],
          "description": "Horizontal text block position."
        },
        "y": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "75vh"
          ],
          "description": "Vertical text block position."
        },
        "size": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "3vh",
            "2vh",
            "2vh",
            "4vh"
          ],
          "description": "Text height per rendered item. Index 0 applies to adapter name, index 1 to each IP."
        },
        "color": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "transparent"
          ],
          "description": "Text color. Set to a valid color to enable rendering."
        },
        "require_adapter_type": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "Wireless80211",
            "Ethernet"
          ],
          "description": "Adapter types to include. Accepts .NET names, IANA short names, or integers. See [network interface types](#about-network-interface-types)."
        },
        "exclude_adapter_type": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Adapter types to exclude. If require_adapter_type is non-empty, exclude_adapter_type is skipped."
        },
        "require_up": {
