{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BgRaster Common Schema Definitions",
  "description": "Shared schema definitions referenced by bgraster-config.schema.json and bgraster-lastrun.schema.json",
  "definitions": {
    "textTable": {
      "type": "object",
      "description": "Global text rendering settings. Array values are resolved by rendered slice sequence with wraparound.",
      "additionalProperties": false,
      "properties": {
        "text": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["${MachineName} output ${OutputIndexPlusOne}", "slice ${SliceLetter}", "${SliceWidth}x${SliceHeight}"],
          "description": "Text lines, supports ${MachineName}, ${OutputWidth}, ${OutputHeight}, ${OutputIndex}, ${OutputIndexPlusOne}, ${OutputLetter}, ${OutputName}, ${SliceWidth}, ${SliceHeight}, ${SliceIndex}, ${SliceIndexPlusOne}, ${SliceLetter}"
        },
        "size": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["3vh", "2vh", "4vh"],
          "description": "Per-line text heights with units (px, vh, vw, vmin, vmax)"
        },
        "color": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["#fff"],
          "description": "Per-line text colors"
        },
        "x": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["75vw"],
          "description": "Text anchor x-coordinate"
        },
        "y": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["75vh"],
          "description": "Text anchor y-coordinate"
        }
      }
    },
    "backgroundTable": {
      "type": "object",
      "description": "Background rendering settings. Array values are resolved by rendered slice sequence with wraparound.",
      "additionalProperties": false,
      "properties": {
        "color": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["#FF0000", "#00FF00", "#0000FF"],
          "description": "Base fill color, cycles by rendered slice sequence with wraparound. Supports #RRGGBB, #RRGGBBAA, rgb(), rgba(), hsl(), hsla()"
        },
        "image": {
          "type": "array",
          "items": { "type": "string" },
          "default": [""],
          "description": "Optional path to background image (SVG or PNG), rendered over color layer. Empty = no image."
        },
        "fit": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["CropTL", "CropTR", "CropC", "CropBL", "CropBR", "BestFit", "CropToFill"]
          },
          "default": ["CropToFill"],
          "description": "Background image fit mode. CropToFill and BestFit use uniform scaling; crop modes do not scale."
        },
        "alternating": {
          "type": "array",
          "items": { "type": "boolean" },
          "default": [false],
          "description": "Enable checkerboard alternating pixel pattern (renders over grid)"
        },
        "border": {
          "type": "array",
          "items": { "type": "boolean" },
          "default": [false],
          "description": "Enable 1-pixel border at viewport edge"
        },
        "border-color": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["#FFFFFF"],
          "description": "Border color"
        }
      }
    },
    "gridTable": {
      "type": "object",
      "description": "Grid rendering settings. Array values are resolved by rendered slice sequence with wraparound.",
      "additionalProperties": false,
      "properties": {
        "size": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["100px"],
          "description": "Checker cell size with units"
        },
        "odd-color": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["#00000080"],
          "description": "Color for odd-indexed grid squares"
        },
        "even-color": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["transparent"],
          "description": "Color for even-indexed grid squares"
        },
        "stroke": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["0"],
          "description": "Grid line width. 0 = filled cells, non-zero = line width"
        },
        "offset-x": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["0"],
          "description": "Horizontal grid phase offset"
        },
        "offset-y": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["0"],
          "description": "Vertical grid phase offset"
        },
        "coordinates": {
          "type": "array",
          "items": { "type": "boolean" },
          "default": [false],
          "description": "Enable pixel coordinate display in each grid square"
        }
      }
    },
    "circleTable": {
      "type": "object",
      "description": "Circle rendering settings. Array values are resolved by rendered slice sequence with wraparound.",
      "additionalProperties": false,
      "properties": {
        "size": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["100vmin"],
          "description": "Circle diameter with units"
        },
        "color": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["#ffffff40"],
          "description": "Circle fill/stroke color"
        },
        "stroke": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["0"],
          "description": "Circle stroke width. 0 = fill only, non-zero = stroke width"
        }
      }
    },
    "crosshairTable": {
      "type": "object",
      "description": "Crosshair rendering settings. Array values are resolved by rendered slice sequence with wraparound.",
      "additionalProperties": false,
      "properties": {
        "length": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["5vmin"],
          "description": "Crosshair arm length (total, not radius)"
        },
        "color": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["#ffffff80"],
          "description": "Crosshair color"
        },
        "stroke": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["1px"],
          "description": "Crosshair line thickness"
        }
      }
    },
    "labeledEdgesTable": {
      "type": "object",
      "description": "Labeled edges rendering settings. Array values are resolved by rendered slice sequence with wraparound.",
      "additionalProperties": false,
      "properties": {
        "text-size": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["10px"],
          "description": "Label text height with units"
        },
        "tail-length": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["10px"],
          "description": "Length of the arrow tail, excluding the head"
        },
        "thickness": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["3px"],
          "description": "Arrow stem thickness with units"
        },
        "head-scale": {
          "type": "array",
          "items": { "type": "number", "minimum": 0 },
          "default": [1.0],
          "description": "Multiplier applied to the arrowhead dimensions"
        },
        "scope": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["Desktop", "Output", "Slice"]
          },
          "default": ["Desktop"],
          "description": "Scope used when resolving viewport-unit measurements and displayed numbers"
        },
        "side": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["TL", "T", "TR", "R", "BR", "B", "BL", "L"]
          },
          "default": ["TL", "T", "TR", "R", "BR", "B", "BL", "L"],
          "description": "Sides or corners to label; values may not repeat"
        }
      }
    },
    "logoTable": {
      "type": "object",
      "description": "Logo rendering settings. Array values are resolved by rendered slice sequence with wraparound.",
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "array",
          "items": { "type": "string" },
          "default": [""],
          "description": "Path to logo image file (SVG or PNG). Empty = no logo. Invalid paths use embedded fallback."
        },
        "x": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["85vw"],
          "description": "Logo center X position"
        },
        "y": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["15vh"],
          "description": "Logo center Y position"
        },
        "width": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["20vw"],
          "description": "Logo fit rectangle width"
        },
        "height": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["20vh"],
          "description": "Logo fit rectangle height"
        },
        "opacity": {
          "type": "array",
          "items": { "type": "number", "minimum": 0, "maximum": 1 },
          "default": [1.0],
          "description": "Additional opacity multiplier (0 = transparent, 1 = opaque)"
        }
      }
    },
    "renderTable": {
      "type": "object",
      "description": "Render and output settings",
      "additionalProperties": false,
      "properties": {
        "no-assignment": {
          "type": "boolean",
          "default": false,
          "description": "Generate PNGs without assigning wallpaper"
        },
        "output": {
          "type": "string",
          "default": "",
          "description": "Output directory override for generated PNGs. Empty = default BgRaster temp directory."
        },
        "verbosity": {
          "type": "string",
          "enum": ["quiet", "normal", "verbose"],
          "default": "normal",
          "description": "Logging verbosity level"
        }
      }
    },
    "textOverride": {
      "type": "object",
      "description": "Per-output or per-slice text override. Only text lines are arrays; other fields are scalar.",
      "additionalProperties": false,
      "properties": {
        "text": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Text lines, supports ${MachineName}, ${OutputWidth}, ${OutputHeight}, ${OutputIndex}, ${OutputIndexPlusOne}, ${OutputLetter}, ${OutputName}, ${SliceWidth}, ${SliceHeight}, ${SliceIndex}, ${SliceIndexPlusOne}, ${SliceLetter}"
        },
        "size": {
          "type": "string",
          "description": "Text size for the override viewport"
        },
        "color": {
          "type": "string",
          "description": "Text color for the override viewport"
        },
        "x": {
          "type": "string",
          "description": "Text anchor x-coordinate for the override viewport"
        },
        "y": {
          "type": "string",
          "description": "Text anchor y-coordinate for the override viewport"
        }
      }
    },
    "backgroundOverride": {
      "type": "object",
      "description": "Per-output or per-slice background override. Scalar values only.",
      "additionalProperties": false,
      "properties": {
        "color": {
          "type": "string",
          "description": "Base fill color"
        },
        "image": {
          "type": "string",
          "description": "Optional path to background image (SVG or PNG)"
        },
        "fit": {
          "type": "string",
          "enum": ["CropTL", "CropTR", "CropC", "CropBL", "CropBR", "BestFit", "CropToFill"],
          "description": "Background image fit mode"
        },
        "alternating": {
          "type": "boolean",
          "description": "Enable checkerboard alternating pixel pattern"
        },
        "border": {
          "type": "boolean",
          "description": "Enable 1-pixel border at viewport edge"
        },
        "border-color": {
          "type": "string",
          "description": "Border color"
        }
      }
    },
    "gridOverride": {
      "type": "object",
      "description": "Per-output or per-slice grid override. Scalar values only.",
      "additionalProperties": false,
      "properties": {
        "size": { "type": "string", "description": "Checker cell size with units" },
        "odd-color": { "type": "string", "description": "Color for odd-indexed grid squares" },
        "even-color": { "type": "string", "description": "Color for even-indexed grid squares" },
        "stroke": { "type": "string", "description": "Grid line width" },
        "offset-x": { "type": "string", "description": "Horizontal grid phase offset" },
        "offset-y": { "type": "string", "description": "Vertical grid phase offset" },
        "coordinates": { "type": "boolean", "description": "Enable pixel coordinate display in each grid square" }
      }
    },
    "circleOverride": {
      "type": "object",
      "description": "Per-output or per-slice circle override. Scalar values only.",
      "additionalProperties": false,
      "properties": {
        "size": { "type": "string", "description": "Circle diameter with units" },
        "color": { "type": "string", "description": "Circle fill/stroke color" },
        "stroke": { "type": "string", "description": "Circle stroke width" }
      }
    },
    "crosshairOverride": {
      "type": "object",
      "description": "Per-output or per-slice crosshair override. Scalar values only.",
      "additionalProperties": false,
      "properties": {
        "length": { "type": "string", "description": "Crosshair arm length" },
        "color": { "type": "string", "description": "Crosshair color" },
        "stroke": { "type": "string", "description": "Crosshair line thickness" }
      }
    },
    "labeledEdgesOverride": {
      "type": "object",
      "description": "Per-output or per-slice labeled edges override.",
      "additionalProperties": false,
      "properties": {
        "text-size": { "type": "string", "description": "Label text height with units" },
        "tail-length": { "type": "string", "description": "Length of the arrow tail, excluding the head" },
        "thickness": { "type": "string", "description": "Arrow stem thickness with units" },
        "head-scale": { "type": "number", "minimum": 0, "description": "Multiplier applied to the arrowhead dimensions" },
        "scope": {
          "type": "string",
          "enum": ["Desktop", "Output", "Slice"],
          "description": "Scope used when resolving viewport-unit measurements and displayed numbers"
        },
        "side": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["TL", "T", "TR", "R", "BR", "B", "BL", "L"]
          },
          "description": "Sides or corners to label; values may not repeat"
        }
      }
    },
    "logoOverride": {
      "type": "object",
      "description": "Per-output or per-slice logo override. Scalar values only.",
      "additionalProperties": false,
      "properties": {
        "source": { "type": "string", "description": "Path to logo image file" },
        "x": { "type": "string", "description": "Logo center X position" },
        "y": { "type": "string", "description": "Logo center Y position" },
        "width": { "type": "string", "description": "Logo fit rectangle width" },
        "height": { "type": "string", "description": "Logo fit rectangle height" },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1, "description": "Additional opacity multiplier" }
      }
    },
    "sliceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": {
          "type": "string",
          "description": "Slice left position in parent output coordinates"
        },
        "y": {
          "type": "string",
          "description": "Slice top position in parent output coordinates"
        },
        "width": {
          "type": "string",
          "description": "Slice width"
        },
        "height": {
          "type": "string",
          "description": "Slice height"
        },
        "text": {
          "$ref": "#/definitions/textOverride"
        },
        "background": {
          "$ref": "#/definitions/backgroundOverride"
        },
        "grid": {
          "$ref": "#/definitions/gridOverride"
        },
        "circle": {
          "$ref": "#/definitions/circleOverride"
        },
        "crosshair": {
          "$ref": "#/definitions/crosshairOverride"
        },
        "labeled-edges": {
          "$ref": "#/definitions/labeledEdgesOverride"
        },
        "logo": {
          "$ref": "#/definitions/logoOverride"
        }
      }
    },
    "sliceList": {
      "type": "array",
      "description": "Per-output slice subdivisions",
      "items": {
        "$ref": "#/definitions/sliceItem"
      }
    },
    "outputItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target"],
      "properties": {
        "target": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "type": "string"
            }
          ],
          "description": "Output matcher: zero-based OS index (integer) or stable OS unique ID (string)"
        },
        "text": {
          "$ref": "#/definitions/textOverride"
        },
        "background": {
          "$ref": "#/definitions/backgroundOverride"
        },
        "grid": {
          "$ref": "#/definitions/gridOverride"
        },
        "circle": {
          "$ref": "#/definitions/circleOverride"
        },
        "crosshair": {
          "$ref": "#/definitions/crosshairOverride"
        },
        "labeled-edges": {
          "$ref": "#/definitions/labeledEdgesOverride"
        },
        "logo": {
          "$ref": "#/definitions/logoOverride"
        },
        "slice": {
          "$ref": "#/definitions/sliceList"
        }
      }
    },
    "outputList": {
      "type": "array",
      "description": "Per-output configuration objects",
      "items": {
        "$ref": "#/definitions/outputItem"
      }
    }
  }
}
