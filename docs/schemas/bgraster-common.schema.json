{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BgRaster Common Schema Definitions",
  "description": "Shared schema definitions referenced by bgraster-config.schema.json and bgraster-lastrun.schema.json",
  "definitions": {
    "textTable": {
      "type": "object",
      "description": "Global text rendering settings. Array values are resolved by rendered slice sequence with wraparound.",
      "x-bgraster-doc": {
        "order": 10,
        "heading": "[text]",
        "showDefaults": true
      },
      "additionalProperties": false,
      "properties": {
        "format": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "${MachineName} output ${OutputIndexPlusOne}<br>",
            "slice ${SliceLetter}<br>",
            "${SliceWidth}x${SliceHeight}"
          ],
          "description": "Text lines. Each array element gets its own color/size index and accumulates on the same visual line until the next element starts. Use <code>&lt;br&gt;</code> for explicit linebreaks. Supports substitution tokens detailed in the [Substitution tokens](#substitution-tokens) table."
        },
        "text-align": {
          "type": "string",
          "enum": [
            "start",
            "end",
            "center"
          ],
          "default": "center",
          "description": "Internal text alignment within the block"
        },
        "anchor-x": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "left",
                "center",
                "right"
              ]
            },
            {
              "type": "number"
            }
          ],
          "default": "center",
          "description": "Horizontal block anchoring. Accepts float values (0 to 1)."
        },
        "anchor-y": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "top",
                "center",
                "bottom"
              ]
            },
            {
              "type": "number"
            }
          ],
          "default": "center",
          "description": "Vertical block anchoring. Accepts float values (0 to 1)."
        },
        "size": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "3vh",
            "2vh",
            "4vh"
          ],
          "description": "Per-line text heights with units (px, vh, vw, vmin, vmax)"
        },
        "color": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "#fff"
          ],
          "description": "Per-line text colors"
        },
        "x": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "75vw"
          ],
          "description": "Text anchor x-coordinate"
        },
        "y": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "75vh"
          ],
          "description": "Text anchor y-coordinate"
        }
      }
    },
    "backgroundTable": {
      "type": "object",
      "description": "Background rendering settings. Array values are resolved by rendered slice sequence with wraparound.",
      "x-bgraster-doc": {
        "order": 20,
        "heading": "[background]",
        "showDefaults": true
      },
      "additionalProperties": false,
      "properties": {
        "color": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "#FF0000",
            "#00FF00",
            "#0000FF"
          ],
          "description": "Base fill color, cycles by rendered slice sequence with wraparound. Supports #RRGGBB, #RRGGBBAA, rgb(), rgba(), hsl(), hsla()"
        },
        "image": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ""
          ],
          "description": "Optional path to background image (SVG or PNG), rendered over color layer. Relative paths resolve against the config file directory. Field substitution is applied. Empty = no image."
        },
        "fit": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "CropTL",
              "CropTR",
              "CropC",
              "CropBL",
              "CropBR",
              "BestFit",
              "CropToFill"
            ]
          },
          "default": [
            "CropToFill"
          ],
          "description": "Background image fit mode. CropToFill and BestFit use uniform scaling; crop modes do not scale."
        },
        "alternating": {
          "type": "array",
          "items": {
            "type": "boolean"
          },
          "default": [
            false
          ],
          "description": "Enable checkerboard alternating pixel pattern (renders over grid)"
        },
        "border": {
          "type": "array",
          "items": {
            "type": "boolean"
          },
          "default": [
            false
          ],
          "description": "Enable 1-pixel border at viewport edge"
        },
        "border-color": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "#FFFFFF"
          ],
          "description": "Border color"
        }
      }
    },
    "gridTable": {
      "type": "object",
      "description": "Grid rendering settings. Array values are resolved by rendered slice sequence with wraparound.",
      "x-bgraster-doc": {
        "order": 30,
        "heading": "[grid]",
        "showDefaults": true
      },
      "additionalProperties": false,
      "properties": {
        "size": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "100px"
          ],
          "description": "Checker cell size with units"
        },
        "odd-color": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "#00000080"
          ],
          "description": "Color for odd-indexed grid squares"
        },
        "even-color": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "transparent"
          ],
          "description": "Color for even-indexed grid squares"
        },
        "stroke": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "0"
          ],
          "description": "Grid line width. 0 = filled cells, non-zero = line width"
        },
        "offset-x": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "0"
          ],
          "description": "Horizontal grid phase offset"
        },
        "offset-y": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "0"
          ],
          "description": "Vertical grid phase offset"
        },
        "coordinates": {
          "type": "array",
          "items": {
            "type": "boolean"
          },
          "default": [
            false
          ],
          "description": "Enable pixel coordinate display in each grid square"
        }
      }
    },
    "circleTable": {
      "type": "object",
      "description": "Circle rendering settings. Array values are resolved by rendered slice sequence with wraparound.",
      "x-bgraster-doc": {
        "order": 40,
        "heading": "[circle]",
        "showDefaults": true
      },
      "additionalProperties": false,
      "properties": {
        "x": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "50vw"
          ],
          "description": "Circle center X coordinate with units"
        },
        "y": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "50vh"
          ],
          "description": "Circle center Y coordinate with units"
        },
        "size": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "100vmin"
          ],
          "description": "Circle diameter with units"
        },
        "color": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "#ffffff40"
          ],
          "description": "Circle fill/stroke color"
        },
        "stroke": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "0"
          ],
          "description": "Circle stroke width. 0 = fill only, non-zero = stroke width"
        }
      }
    },
    "crosshairTable": {
      "type": "object",
      "description": "Crosshair rendering settings. Array values are resolved by rendered slice sequence with wraparound.",
      "x-bgraster-doc": {
        "order": 50,
        "heading": "[crosshair]",
        "showDefaults": true
      },
      "additionalProperties": false,
      "properties": {
        "x": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "50vw"
          ],
          "description": "Crosshair center X coordinate with units"
        },
        "y": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "50vh"
          ],
          "description": "Crosshair center Y coordinate with units"
        },
        "length": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "5vmin"
          ],
          "description": "Crosshair arm length (total, not radius)"
