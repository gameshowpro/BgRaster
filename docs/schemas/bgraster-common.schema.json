        "color": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "#ffffff80"
          ],
          "description": "Crosshair color"
        },
        "stroke": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "1px"
          ],
          "description": "Crosshair line thickness"
        }
      }
    },
    "labeledEdgesTable": {
      "type": "object",
      "description": "Labeled edges rendering settings. Array values are resolved by rendered slice sequence with wraparound.",
      "x-bgraster-doc": {
        "order": 60,
        "heading": "[labeled-edges]",
        "showDefaults": true
      },
      "additionalProperties": false,
      "properties": {
        "text-size": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "10px"
          ],
          "description": "Label text height with units"
        },
        "tail-length": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "10px"
          ],
          "description": "Length of the arrow tail, excluding the head"
        },
        "thickness": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "3px"
          ],
          "description": "Arrow stem thickness with units"
        },
        "head-scale": {
          "type": "array",
          "items": {
            "type": "number",
            "minimum": 0
          },
          "default": [
            1.0
          ],
          "description": "Multiplier applied to the arrowhead dimensions"
        },
        "scope": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Desktop",
              "Output",
              "Slice"
            ]
          },
          "default": [
            "Desktop"
          ],
          "description": "Scope used when resolving viewport-unit measurements and displayed numbers"
        },
        "side": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "TL",
              "T",
              "TR",
              "R",
              "BR",
              "B",
              "BL",
              "L"
            ]
          },
          "default": [
            "TL",
            "T",
            "TR",
            "R",
            "BR",
            "B",
            "BL",
            "L"
          ],
          "description": "Sides or corners to label; values may not repeat"
        }
      }
    },
    "logoTable": {
      "type": "object",
      "description": "Logo rendering settings. Array values are resolved by rendered slice sequence with wraparound.",
      "x-bgraster-doc": {
        "order": 70,
        "heading": "[logo]",
        "showDefaults": true
      },
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "pack://application:,,,/GameshowPro.BgRaster;component/resources/BgRaster.svg"
          ],
          "description": "Path to logo image file (SVG or PNG), pack URI to embedded resource, or empty string to suppress. Relative file paths resolve against the config file directory. Field substitution is applied. Pack URIs use format: pack://application:,,,/GameshowPro.BgRaster;component/path/to/resource. If path is invalid/missing, falls back to embedded logo."
        },
        "x": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "85vw"
          ],
          "description": "Logo center X position"
        },
        "y": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "15vh"
          ],
          "description": "Logo anchor Y position"
        },
        "anchor-x": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "left",
                "center",
                "right"
              ]
            },
            {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          ],
          "default": "center",
          "description": "Horizontal block anchoring. Accepts float values (0 to 1)."
        },
        "anchor-y": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "top",
                "center",
                "bottom"
              ]
            },
            {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          ],
          "default": "center",
          "description": "Vertical block anchoring. Accepts float values (0 to 1)."
        },
        "width": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Logo fit rectangle width. If unset, computed from height and the logo source's natural aspect ratio."
        },
        "height": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "20vh"
          ],
          "description": "Logo fit rectangle height. If unset, computed from width and the logo source's natural aspect ratio."
        },
        "opacity": {
          "type": "array",
          "items": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "default": [
            1.0
          ],
          "description": "Additional opacity multiplier (0 = transparent, 1 = opaque)"
        }
      }
    },
    "renderTable": {
      "type": "object",
      "description": "Render and output settings. Some settings are required for simulating output, such as when generating samples.",
      "x-bgraster-doc": {
        "order": 80,
        "heading": "[render]",
        "showDefaults": true
      },
      "additionalProperties": false,
      "properties": {
        "no-assignment": {
          "type": "boolean",
          "default": false,
          "description": "Generate PNGs without assigning wallpaper"
        },
        "no-discovery": {
          "type": "boolean",
          "default": false,
          "description": "Skip display discovery and render only configured [[output]] entries using [output.hardware_output]. Implies no-assignment."
        },
        "outputs-skip-unspecified": {
          "type": "boolean",
          "default": false,
          "description": "When false, discovered outputs without matching [[output]] entries are still rendered with global settings"
        },
        "output": {
          "type": "string",
          "default": "",
          "description": "Output path template for generated PNGs (directory + filename stem). Relative paths resolve against the config file directory. `${  }` field substitution tokens and `{now}`, `{index}`, `{friendlyName}` file-naming tokens are both supported. Empty = %TEMP%/BgRaster/{now}_{index}."
        },
        "force": {
          "type": "boolean",
          "default": false,
          "description": "Continue rendering even when run-skipped-unchanged would normally short-circuit"
        },
        "verbosity": {
          "type": "string",
          "enum": [
            "quiet",
            "normal",
            "verbose"
          ],
          "default": "normal",
          "description": "Logging verbosity level"
        },
        "machine-name": {
          "type": "string",
          "default": "",
          "description": "Override the framework-supplied host name used by ${MachineName} substitutions. Empty uses Environment.MachineName."
        },
        "simulate-network": {
          "type": "boolean",
          "default": false,
          "description": "If true, uses a built-in network simulator instead of querying real network interfaces. Useful for testing and sample generation."
        }
      }
    },
    "textOverride": {
      "type": "object",
      "description": "Per-output or per-slice text override. Only text lines are arrays; other fields are scalar.",
      "additionalProperties": false,
      "properties": {
        "text": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Text lines, supports ${MachineName}, ${OutputWidth}, ${OutputHeight}, ${OutputIndex}, ${OutputIndexPlusOne}, ${OutputLetter}, ${OutputName}, ${SliceWidth}, ${SliceHeight}, ${SliceIndex}, ${SliceIndexPlusOne}, ${SliceLetter}"
        },
        "text-align": {
          "type": "string",
          "enum": [
