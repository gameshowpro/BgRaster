        "surface": "both",
        "description": "Override the framework-supplied host name used by ${MachineName} substitutions.",
        "defaultResolution": "if omitted, searches for `config.toml` in this order: next to the executable, `%ProgramData%\\BgRaster`, `%LocalAppData%\\BgRaster`, `%AppData%\\BgRaster`; if none exist, starts from built-in defaults.",
        "category": "Advanced"
      },
      {
        "key": "text-format",
        "alias": "--text-format",
        "valueSyntax": "<s|[\"s1\",\"s2\"]>",
        "typeName": "string",
        "parseKind": "string",
        "tomlEquivalent": "[text].format",
        "tomlPath": "[text].format",
        "surface": "both",
        "description": "Text line(s); accepts a single string or a TOML string array literal.",
        "defaultResolution": "if omitted, defers to `config.toml` `[text].format`; if missing there, uses `[\"${MachineName} output ${OutputIndexPlusOne}\", \"slice ${SliceLetter}\", \"${SliceWidth}x${SliceHeight}\"]`.",
