{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BgRaster Configuration Schema",
  "description": "Schema for BgRaster user configuration files (config.toml). Include a $schema comment at the top: # $schema: https://raw.githubusercontent.com/gameshowpro/BgRaster/refs/heads/main/docs/schemas/bgraster-config.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "machine-name": {
      "type": "string",
      "default": "",
      "description": "Override the framework-supplied host name used by ${MachineName} substitutions. Empty uses Environment.MachineName."
    },
    "text": {
      "$ref": "./bgraster-common.schema.json#/definitions/textTable"
    },
    "background": {
      "$ref": "./bgraster-common.schema.json#/definitions/backgroundTable"
    },
    "grid": {
      "$ref": "./bgraster-common.schema.json#/definitions/gridTable"
    },
    "circle": {
      "$ref": "./bgraster-common.schema.json#/definitions/circleTable"
    },
    "crosshair": {
      "$ref": "./bgraster-common.schema.json#/definitions/crosshairTable"
    },
    "labeled-edges": {
      "$ref": "./bgraster-common.schema.json#/definitions/labeledEdgesTable"
    },
    "logo": {
      "$ref": "./bgraster-common.schema.json#/definitions/logoTable"
    },
    "render": {
      "$ref": "./bgraster-common.schema.json#/definitions/renderTable"
    },
    "output": {
      "$ref": "./bgraster-common.schema.json#/definitions/outputList"
    }
  }
}
