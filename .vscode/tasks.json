{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build BgRaster (Debug win-x64)",
            "type": "process",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/src/BgRaster.csproj",
                "-c",
                "Debug",
                "-r",
                "win-x64"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "install docs dependencies",
            "type": "process",
            "command": "python",
            "args": [
                "-m",
                "pip",
                "install",
                "-r",
                "${workspaceFolder}/docs/requirements.txt"
            ],
            "problemMatcher": []
        },
        {
            "label": "serve docs (mkdocs)",
            "type": "process",
            "command": "pwsh",
            "args": [
                "-NoLogo",
                "-NoProfile",
                "-Command",
                "& '${workspaceFolder}/scripts/generate-documentation.ps1'; python -m mkdocs serve --dev-addr 127.0.0.1:8000"
            ],
            "isBackground": true,
            "problemMatcher": []
        }
    ]
}
